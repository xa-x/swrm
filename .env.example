# ==================
# CONVEX
# ==================
CONVEX_URL=https://your-name.convex.cloud
CONVEX_DEPLOYMENT=your-deployment

# ==================
# FLY.IO (Container Hosting)
# ==================
FLY_API_TOKEN=your_fly_token_here
FLY_APP_NAME=swrm-agents

# ==================
# CLERK (Authentication)
# ==================
EXPO_PUBLIC_CLERK_KEY=pk_test_your_clerk_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret

# ==================
# OPTIONAL: Platform API Keys
# ==================
# If you want to provide LLM for users (credit system)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ZHIPU_API_KEY=...

# ==================
# APP-SPECIFIC
# ==================
# Native app
EXPO_PUBLIC_CONVEX_URL=https://your-name.convex.cloud

# Web app (when ready)
NEXT_PUBLIC_CONVEX_URL=https://your-name.convex.cloud
NEXT_PUBLIC_CLERK_KEY=pk_test_your_clerk_key
